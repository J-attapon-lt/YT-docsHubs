rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActive() {
      return signedIn() && userProfile().active == true;
    }

    function role() {
      return userProfile().role;
    }

    function isAdmin() {
      return isActive() && role() == 'admin';
    }

    function isEditor() {
      return isActive() && (role() == 'admin' || role() == 'editor');
    }

    function isSupervisor() {
      return isActive() && (role() == 'admin' || role() == 'supervisor');
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    match /artifacts/{appId}/public/data/documents/{documentId} {
      allow read: if resource.data.status == 'published'
        && (
          !('allowedRoles' in resource.data)
          || resource.data.allowedRoles.hasAny(['viewer'])
          || (signedIn() && resource.data.allowedRoles.hasAny([role()]))
        );
      allow create, update: if isEditor();
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isEditor();
      allow update, delete: if false;
    }
  }
}
